# Database
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=sm_visitor

# Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY_DAYS=7
OTP_EXPIRY_MINUTES=5

# Storage
# Options: "local" (GridFS + local buffer) or "cloudinary"
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# S3 (if using cloud storage instead of Cloudinary)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Cloudinary (if using Cloudinary for image storage)
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_FOLDER=sm-visitor/photos

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# App URLs
ORBIT_URL=http://localhost:3000
HORIZON_URL=http://localhost:3001
PANTRY_URL=http://localhost:8000
